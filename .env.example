# Algorand DEX Environment
# Copy this file to .env and fill in values

# Network
ALGORAND_NETWORK=testnet
ALGOD_SERVER=https://testnet-api.algonode.cloud
ALGOD_PORT=443
ALGOD_TOKEN=
INDEXER_SERVER=https://testnet-idx.algonode.cloud
INDEXER_PORT=443
INDEXER_TOKEN=

# Deployer
DEPLOYER_MNEMONIC=

# Contract Config (auto-populated by npm run deploy)
APP_ID=
ASSET_B_ID=
LP_TOKEN_ID=

# API Server
PORT=3000
API_PORT=3000
API_HOST=0.0.0.0
JWT_SECRET=change-me-in-production
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Webhooks
WEBHOOK_SECRET=change-me-in-production
