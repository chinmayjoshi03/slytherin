{
  "name": "slytherin-dex",
  "version": "1.0.0",
  "description": "Frontendless DEX — API-first decentralized exchange on Algorand",
  "main": "smart_contracts/index.ts",
  "scripts": {
    "build": "algokit compile ts smart_contracts --output-source-map --out-dir artifacts && algokit generate client smart_contracts/artifacts --output {app_spec_dir}/{contract_name}Client.ts",
    "deploy": "ts-node --transpile-only -r dotenv/config scripts/deploy.ts",
    "deploy:ci": "ts-node --transpile-only -r dotenv/config scripts/deploy.ts",
    "check-types": "tsc --noEmit",
    "dev": "npm run api",
    "api": "ts-node-dev --transpile-only --watch .env -r dotenv/config api/server.ts",
    "api:start": "ts-node --transpile-only -r dotenv/config api/server.ts",
    "cli": "ts-node --transpile-only -r dotenv/config cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22.0",
    "npm": ">=9.0"
  },
  "dependencies": {
    "@algorandfoundation/algorand-typescript": "^1.0.1",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "express-rate-limit": "^7.4.0",
    "ws": "^8.18.0",
    "jsonwebtoken": "^9.0.2",
    "commander": "^12.1.0",
    "uuid": "^10.0.0",
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "@algorandfoundation/algokit-client-generator": "^6.0.0",
    "@algorandfoundation/algokit-utils": "^9.0.0",
    "@algorandfoundation/algokit-utils-debug": "^1.0.4",
    "@algorandfoundation/puya-ts": "^1.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@tsconfig/node22": "^22.0.0",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/ws": "^8.5.12",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/uuid": "^10.0.0",
    "algosdk": "^3.0.0",
    "dotenv": "^16.4.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.0"
  },
  "overrides": {
    "esbuild": "0.25.0"
  }
}
